generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum RequestStatus {
  PENDING_MANAGER
  PENDING_DEPARTMENT
  NEEDS_INFO
  APPROVED
  ARCHIVED
  REJECTED
}

enum AuditAction {
  CREATE
  TRANSITION
  DELEGATE
}

model User {
  id               String            @id @default(cuid())
  displayName      String
  email            String?           @unique
  passwordHash     String?
  role             Role              @default(USER)
  department       String?
  isDepartmentHead Boolean           @default(false)
  managerId        String?
  manager          User?             @relation("UserManager", fields: [managerId], references: [id])
  subordinates     User[]            @relation("UserManager")
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  requests         WorkflowRequest[] @relation("SubmittedRequests")
  assignedRequests WorkflowRequest[] @relation("AssignedRequests")
  auditLogs        RequestAuditLog[]

  @@index([displayName])
}

model WorkflowRequest {
  id          Int               @id @default(autoincrement())
  title       String
  description String            @default("")
  category    String            @default("GENERAL")
  amountCents Int?
  status      RequestStatus     @default(PENDING_MANAGER)
  isDeleted   Boolean           @default(false)
  dueAt       DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  submitterId String
  submitter   User              @relation("SubmittedRequests", fields: [submitterId], references: [id])
  assignedToId String?
  assignedTo   User?            @relation("AssignedRequests", fields: [assignedToId], references: [id])
  history     RequestAuditLog[]
  attachments Attachment[]

  @@index([status, updatedAt])
  @@index([submitterId, createdAt])
  @@index([assignedToId, dueAt])
}

model RequestAuditLog {
  id          String          @id @default(cuid())
  requestId   Int
  request     WorkflowRequest @relation(fields: [requestId], references: [id])
  actorId     String
  actor       User            @relation(fields: [actorId], references: [id])
  action      AuditAction
  fromStatus  RequestStatus?
  toStatus    RequestStatus
  note        String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime        @default(now())

  @@index([requestId, createdAt])
  @@index([actorId, createdAt])
}

model Attachment {
  id          String          @id @default(cuid())
  requestId   Int
  request     WorkflowRequest @relation(fields: [requestId], references: [id])
  filename    String
  path        String
  mimetype    String
  sizeBytes   Int
  createdAt   DateTime        @default(now())

  @@index([requestId])
}
