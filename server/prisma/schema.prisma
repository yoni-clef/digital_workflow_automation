generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum RequestStatus {
  PENDING_MANAGER
  PENDING_DEPARTMENT
  NEEDS_INFO
  APPROVED
  ARCHIVED
  REJECTED
}

enum AuditAction {
  CREATE
  TRANSITION
  DELEGATE
}

enum ManagerRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String            @id @default(cuid())
  displayName      String
  email            String?           @unique
  passwordHash     String?
  role             Role              @default(USER)
  department       String?
  isDepartmentHead Boolean           @default(false)
  managerId        String?
  manager          User?             @relation("UserManager", fields: [managerId], references: [id])
  subordinates     User[]            @relation("UserManager")
  requests         WorkflowRequest[] @relation("SubmittedRequests")
  assignedRequests WorkflowRequest[] @relation("AssignedRequests")
  auditLogs        RequestAuditLog[]
  attachments     Attachment[]
  departmentHeads User[]             @relation("DepartmentHead")
  managedBy        User?             @relation("DepartmentHead", fields: [departmentHeadId])
  departmentHeadId String?
  hasRequestedManager Boolean           @default(false)
  managerRequestCreatedAt DateTime?
  managerRequests  ManagerRequest[]     @relation("UserManagerRequests")
  requestedByUsers ManagerRequest[]   @relation("RequestedManager")
  reviewingRequests ManagerRequest[]   @relation("ReviewingAdmin")

  @@index([displayName])
  @@index([email])
}

model WorkflowRequest {
  id          Int               @id @default(autoincrement())
  title       String
  description String            @default("")
  category    String            @default("GENERAL")
  amountCents Int?
  status      RequestStatus     @default(PENDING_MANAGER)
  isDeleted   Boolean           @default(false)
  dueAt       DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  submitterId String
  submitter   User              @relation("SubmittedRequests", fields: [submitterId], references: [id])
  assignedToId String?
  assignedTo   User?            @relation("AssignedRequests", fields: [assignedToId], references: [id])
  history     RequestAuditLog[]
  attachments Attachment[]

  @@index([status, updatedAt])
  @@index([submitterId, createdAt])
  @@index([assignedToId, dueAt])
}

model ManagerRequest {
  id                  String              @id @default(cuid())
  user                User                @relation("UserManagerRequests", fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  requestedManager     User?               @relation("RequestedManager", fields: [requestedManagerId], references: [id])
  requestedManagerId   String?
  status              ManagerRequestStatus @default(PENDING)
  reason              String?
  createdAt           DateTime            @default(now())
  reviewedAt          DateTime?
  reviewedByAdmin      User?               @relation("ReviewingAdmin", fields: [reviewedByAdminId], references: [id])
  reviewedByAdminId    String?
  
  @@unique([userId])
}

model RequestAuditLog {
  id          String          @id @default(cuid())
  requestId   Int
  request     WorkflowRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User            @relation(fields: [actorId], references: [id])
  action      AuditAction
  fromStatus  RequestStatus?
  toStatus    RequestStatus
  note        String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime        @default(now())

  @@index([requestId, createdAt])
  @@index([actorId, createdAt])
}

model Attachment {
  id          String          @id @default(cuid())
  requestId   Int
  request     WorkflowRequest @relation(fields: [requestId], references: [id])
  filename    String
  path        String
  mimetype    String
  sizeBytes   Int
  createdAt   DateTime        @default(now())

  @@index([requestId])
}
